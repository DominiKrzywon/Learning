    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "prettier": "3.6.2",
    "typescript-eslint": "^8.44.1"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
